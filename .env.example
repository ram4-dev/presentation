# ─── LLM provider ─────────────────────────────────────────────────────────
# Any OpenAI-compatible /chat/completions endpoint works.
# Pick ONE option below and copy it to your real .env (or to Vercel env vars).

# ── Option A: Groq (default, fast + has free tier) ────────────────────────
# Get a key at https://console.groq.com/keys
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
# Other Groq models worth trying:
#   llama-3.3-70b-versatile         (higher quality, but only 12k TPM on free tier)
#   moonshotai/kimi-k2-instruct     (strong instruction following)
#   qwen/qwen3-32b                  (great bilingual ES/EN)
#   openai/gpt-oss-120b             (highest quality available on Groq)

# ── Option B: OpenCode Go ─────────────────────────────────────────────────
# Get a key at https://opencode.ai (subscribe to Go: $5/mo first month, $10 after).
# LLM_API_KEY=
# LLM_BASE_URL=https://opencode.ai/zen/go/v1
# LLM_MODEL=qwen3.6-plus

# ── Option C: OpenAI (or any other OpenAI-compatible provider) ────────────
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# Backwards-compatible aliases (also accepted): OPENCODE_API_KEY,
# OPENCODE_BASE_URL, OPENCODE_MODEL.
